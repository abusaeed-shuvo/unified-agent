# Unified Agent Environment Configuration

# LLM Configuration
UA_LLM_PROVIDER=fake
UA_LLM_BASE_URL=http://localhost:1234/v1
UA_LLM_MODEL=local-model

# Database
UA_DATABASE_URL=sqlite+aiosqlite:///./unified_agent.db

# Personality
UA_ACTIVE_PERSONALITY=assistant

# Discord (optional)
UA_DISCORD_TOKEN=

# Logging
UA_LOG_LEVEL=INFO

# Tools
UA_TOOLS_ALLOW_DESTRUCTIVE=false

# Tool Call Loop
UA_MAX_TOOL_CALL_ROUNDS=3
