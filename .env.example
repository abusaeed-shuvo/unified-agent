# Unified Agent Environment Configuration

# LLM Configuration
UA_LLM_PROVIDER=fake
UA_LLM_BASE_URL=http://localhost:1234/v1
UA_LLM_MODEL=local-model

# Retry Configuration for LLM Adapter Failures
UA_LLM_MAX_RETRIES=2
UA_LLM_RETRY_BACKOFF_SECONDS=0.5

# Database
UA_DATABASE_URL=sqlite+aiosqlite:///./unified_agent.db

# Personality
UA_ACTIVE_PERSONALITY=assistant

# Discord (optional)
UA_DISCORD_TOKEN=

# Logging
UA_LOG_LEVEL=INFO

# Tools
UA_TOOLS_ALLOW_DESTRUCTIVE=false

# Tool Call Loop
UA_MAX_TOOL_CALL_ROUNDS=3

# Sandbox SSH Configuration (optional)
# These are NOT set by default. If sandbox_host is not configured, the
# sandbox tools (sandbox_write_file, sandbox_execute) will fail closed
# with an error rather than attempting any connection. This is intentional
# for safety - do not point sandbox tools at a real host until destructive
# command detection (Batch 35) is implemented.
#
# SECURITY WARNING - MITM VULNERABILITY:
# known_hosts=None is used to accept any host key. This is intentional for
# sandbox use where the host is disposable and operated by the user, but
# means a malicious actor on the network could intercept connections. Only
# use this with a trusted, isolated sandbox host.
# UA_SANDBOX_HOST=
# UA_SANDBOX_PORT=22
# UA_SANDBOX_USERNAME=
# UA_SANDBOX_KEY_PATH=~/.ssh/sandbox_key